#!/usr/bin/env bash
# Sample convenience stand-in for a Gradle wrapper.
#
# A real project has a proper Gradle wrapper here (generated by `gradle wrapper`), which pins and
# downloads a specific Gradle version. This sample intentionally ships a tiny shim instead so it can
# run wherever a Gradle is already on PATH, without downloading a distribution. Replace it with a real
# wrapper (or point PROJECT_DIR at your own wrapper-equipped project) in actual use.
set -euo pipefail
if command -v gradle >/dev/null 2>&1; then
  exec gradle "$@"
fi
echo "sample-lib: no 'gradle' on PATH — install Gradle or add a real ./gradlew wrapper." >&2
exit 127
