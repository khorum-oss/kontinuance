# Copy to deploy/.env and adjust. Placeholders only — never commit real secret values.
#
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up --build

# Host port the UI is published on — the single origin you open in a browser.
KONTINUANCE_WEB_PORT=8080

# Internal address the web container proxies to (compose service DNS). Rarely changed.
KONTINUANCE_BACKEND=http://server:8077

# Where the server keeps run history inside its container (mapped to the named volume).
KONTINUANCE_STORE=/data/runs

# Descriptor path inside the server container (the compose file mounts deploy/kontinuance.yml here).
KONTINUANCE_CONFIG_DESCRIPTOR=/etc/kontinuance/kontinuance.yml

# Pipeline secret referenced by the demo descriptor's deploy step. Set a real value locally.
DEPLOY_TOKEN=changeme

# Dev override only (docker-compose.dev.yml): host port to publish the server on directly.
KONTINUANCE_SERVER_PORT=8077
